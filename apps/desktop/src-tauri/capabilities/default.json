{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "/**" },
        { "path": "/**/.*/**" },
        { "path": "/**/.attachments/**" },
        { "path": "/**/.versions/**" }
      ]
    },
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "mic-recorder:default",
    "deep-link:default"
  ]
}
