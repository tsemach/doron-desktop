{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "doron-desktop",
  "version": "0.0.5",
  "identifier": "com.tsemach.doron-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "doron-desktop",
        "width": 1000,
        "height": 800,
        "visible": false,
        "additionalBrowserArgs": "--disable-gpu"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma"
      }
    }
  }
}
