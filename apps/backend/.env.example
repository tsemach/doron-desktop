# PostgreSQL Database Connection URL
DATABASE_URL="postgresql://postgres:password123@localhost:5432/doron_db?schema=public"

# Resend (email verification) -- omit both to fall back to the mock provider
# (logs the verification link to the server console instead of sending it).
RESEND_API_KEY=""
# Defaults to onboarding@resend.dev if unset -- Resend's own docs say not to
# use that in production; swap in a verified-domain address once one exists.
RESEND_SEND_ADDRESS=""
